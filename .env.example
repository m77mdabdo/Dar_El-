APP_NAME="Dar El Jamila"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Bounds how long a single mail send (sync OR queued) can hang on a slow
# or unreachable SMTP host, in seconds. Without this, a bad connection
# blocks for PHP's default socket timeout instead of failing fast.
MAIL_TIMEOUT=10

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Comma-separated list of enabled OAuth providers (e.g. google,facebook).
# Each provider named here also needs its own config block in
# config/services.php and a matching Socialite driver installed.
OAUTH_PROVIDERS=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="${APP_URL}/auth/google/callback"

# Invoice PDFs are rendered via headless Chrome (spatie/browsershot). Leave
# these blank after a plain `npm install puppeteer` on the server — it
# downloads its own bundled Chromium and needs no path configuration. Only
# set them to point at an existing system Chrome/Chromium install instead.
BROWSERSHOT_CHROME_PATH=
BROWSERSHOT_NODE_BINARY=
BROWSERSHOT_NPM_BINARY=

# Free key from https://www.pexels.com/api/ — only needed to run
# `php artisan demo:import` (downloads real demo catalog photos).
PEXELS_API_KEY=

# Web Push (browser notifications for back-in-stock alerts and order-status
# updates). Generate a keypair with `php artisan webpush:vapid` directly on
# each environment — never copy the same keypair between local/staging/prod.
# Leaving these blank simply disables push (subscribe requests are rejected
# safely; mail/database notifications are unaffected either way).
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=

VITE_APP_NAME="${APP_NAME}"
